<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --navy:#1a2545;--navy-light:#263059;--navy-mid:#334170;
  --accent:#d4b85e;--accent-light:#e8d48a;
  --teal:#1ab0c2;--teal-dark:#0e9aab;
  --white:#ffffff;--gray-100:#f5f5f7;--gray-200:#e8e8ec;
  --gray-400:#b0b0c0;--gray-600:#8a8aa0;
  --success:#4caf50;--font-sans:'Inter',system-ui,sans-serif;
  --font-display:'Playfair Display',Georgia,serif;
}
html{scroll-behavior:smooth;font-size:16px}
body{font-family:var(--font-sans);background:var(--navy);color:var(--white);overflow-x:hidden}
.sidebar{position:fixed;left:0;top:0;width:260px;height:100vh;background:var(--navy);
  border-right:1px solid rgba(255,255,255,0.10);z-index:100;display:flex;flex-direction:column;padding:32px 24px}
.sidebar-logo{font-family:var(--font-display);font-size:22px;font-weight:700;letter-spacing:3px;color:var(--white);margin-bottom:4px}
.sidebar-sub{font-size:10px;letter-spacing:4px;color:var(--accent);text-transform:uppercase;margin-bottom:40px;font-weight:500}
.sidebar nav{flex:1}
.sidebar nav a{display:block;padding:12px 0;font-size:12px;letter-spacing:2px;text-transform:uppercase;color:var(--gray-400);text-decoration:none;border-left:2px solid transparent;padding-left:16px;transition:all .3s}
.sidebar nav a:hover,.sidebar nav a.active{color:var(--white);border-left-color:var(--accent)}
.sidebar-footer{margin-top:auto}
.sidebar-footer a{display:flex;align-items:center;gap:8px;font-size:11px;letter-spacing:1px;text-transform:uppercase;color:var(--teal);text-decoration:none;padding:8px 0;transition:color .3s}
.sidebar-footer a:hover{color:var(--accent-light)}
.main{margin-left:260px}
.hero{position:relative;height:100vh;display:flex;align-items:center;justify-content:center;overflow:hidden;background:linear-gradient(135deg,var(--navy) 0%,#0d1220 100%)}
.hero-bg{position:absolute;inset:0;background:linear-gradient(180deg,rgba(15,20,40,.3) 0%,rgba(15,20,40,.7) 100%),url('IMAGE_PLACEHOLDER') center/cover;filter:brightness(0.6) saturate(.85)}
.hero-content{position:relative;text-align:center;max-width:800px;padding:0 40px}
.hero-badge{display:inline-block;background:rgba(201,169,78,.15);border:1px solid var(--accent);padding:8px 24px;border-radius:4px;font-size:11px;letter-spacing:3px;text-transform:uppercase;color:var(--accent);margin-bottom:32px}
.hero h1{font-family:var(--font-display);font-size:clamp(48px,6vw,80px);font-weight:700;line-height:1.05;margin-bottom:16px;letter-spacing:-1px}
.hero h2{font-size:16px;letter-spacing:6px;text-transform:uppercase;color:var(--gray-400);font-weight:400;margin-bottom:40px}
.hero-stats{display:flex;justify-content:center;gap:48px;margin-top:40px}
.hero-stat{text-align:center}
.hero-stat .val{font-size:32px;font-weight:800;color:var(--accent)}
.hero-stat .label{font-size:10px;letter-spacing:2px;text-transform:uppercase;color:var(--gray-400);margin-top:4px}
.scroll-indicator{position:absolute;bottom:40px;left:50%;transform:translateX(-50%);animation:bounce 2s infinite}
@keyframes bounce{0%,100%{transform:translateX(-50%) translateY(0)}50%{transform:translateX(-50%) translateY(10px)}}
.scroll-indicator svg{width:24px;height:24px;color:var(--gray-400)}
.nav-cards{display:grid;grid-template-columns:repeat(5,1fr);gap:16px;padding:40px 48px;background:var(--navy-light)}
.nav-card{background:var(--white);border-radius:8px;overflow:hidden;text-align:center;cursor:pointer;transition:transform .3s,box-shadow .3s;text-decoration:none}
.nav-card:hover{transform:translateY(-4px);box-shadow:0 12px 40px rgba(0,0,0,.4)}
.nav-card img{width:100%;height:120px;object-fit:cover}
.nav-card .nav-label{padding:14px 8px;font-size:11px;letter-spacing:2px;text-transform:uppercase;color:var(--navy);font-weight:600}
section{padding:80px 48px}
.section-header{position:relative;height:400px;display:flex;align-items:flex-end;padding:48px;margin:-80px -48px 60px;overflow:hidden;border-radius:12px}
.section-header .bg{position:absolute;inset:0;background-size:cover;background-position:center;filter:brightness(0.55)}
.section-header .bg::after{content:'';position:absolute;inset:0;background:linear-gradient(180deg,transparent 40%,rgba(15,20,40,.9) 100%)}
.section-header h2{position:relative;font-family:var(--font-display);font-size:clamp(36px,4vw,56px);font-weight:700;letter-spacing:-0.5px}
.overview-grid{display:grid;grid-template-columns:1fr 1fr;gap:48px;margin-top:48px}
.overview-card{background:var(--navy-light);border-radius:12px;padding:36px;border:1px solid rgba(255,255,255,0.10)}
.overview-card h3{font-size:12px;letter-spacing:3px;text-transform:uppercase;color:var(--accent);margin-bottom:24px;font-weight:600}
.overview-card .big-num{font-size:48px;font-weight:800;line-height:1;margin-bottom:8px}
.overview-card .big-label{font-size:13px;color:var(--gray-400);margin-bottom:24px}
.detail-row{display:flex;justify-content:space-between;padding:12px 0;border-bottom:1px solid rgba(255,255,255,0.10)}
.detail-row:last-child{border-bottom:none}
.detail-row .key{font-size:13px;color:var(--gray-400);font-weight:500}
.detail-row .val{font-size:13px;font-weight:600}
.stat-strip{display:grid;grid-template-columns:repeat(5,1fr);gap:24px;padding:48px;background:var(--navy-mid);border-radius:12px;margin:60px 0}
.stat-item{text-align:center}
.stat-item .num{font-size:36px;font-weight:800;color:var(--accent);line-height:1}
.stat-item .desc{font-size:10px;letter-spacing:2px;text-transform:uppercase;color:var(--gray-400);margin-top:8px;font-weight:500}
.highlights-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:24px;margin-top:40px}
.highlight-card{display:flex;gap:20px;background:var(--navy-light);border-radius:12px;padding:28px;border:1px solid rgba(255,255,255,0.10);transition:border-color .3s}
.highlight-card:hover{border-color:var(--accent)}
.highlight-icon{flex-shrink:0;width:48px;height:48px;background:rgba(201,169,78,.12);border-radius:10px;display:flex;align-items:center;justify-content:center}
.highlight-icon svg{width:24px;height:24px;color:var(--accent)}
.highlight-card h4{font-size:14px;font-weight:700;margin-bottom:6px}
.highlight-card p{font-size:13px;color:var(--gray-400);line-height:1.6}
.lease-table{width:100%;border-collapse:collapse;margin-top:32px}
.lease-table thead{background:var(--navy-mid)}
.lease-table th{padding:14px 20px;font-size:11px;letter-spacing:2px;text-transform:uppercase;color:var(--accent);text-align:left;font-weight:600}
.lease-table td{padding:14px 20px;font-size:14px;border-bottom:1px solid rgba(255,255,255,0.10)}
.lease-table tbody tr:hover{background:rgba(255,255,255,.02)}
.cf-table{width:100%;border-collapse:collapse;margin-top:32px;font-size:13px}
.cf-table thead{background:var(--navy-mid)}
.cf-table th{padding:12px 14px;font-size:10px;letter-spacing:1.5px;text-transform:uppercase;color:var(--accent);text-align:right;font-weight:600}
.cf-table th:first-child{text-align:left}
.cf-table td{padding:12px 14px;text-align:right;border-bottom:1px solid rgba(255,255,255,0.10)}
.cf-table td:first-child{text-align:left;font-weight:600}
.cf-table tbody tr:hover{background:rgba(255,255,255,.02)}
.cf-table .total-row{background:var(--navy-mid);font-weight:700}
.returns-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:24px;margin-top:40px}
.return-card{background:var(--navy-light);border-radius:12px;padding:32px;text-align:center;border:1px solid rgba(255,255,255,0.10)}
.return-card .metric{font-size:42px;font-weight:800;color:var(--accent);line-height:1}
.return-card .metric-label{font-size:11px;letter-spacing:2px;text-transform:uppercase;color:var(--gray-400);margin-top:8px}
.return-card.verdict{border-color:var(--success);background:rgba(76,175,80,.08)}
.return-card.verdict .metric{color:var(--success)}
.sensitivity-table{width:100%;border-collapse:collapse;margin-top:32px}
.sensitivity-table th{padding:14px;font-size:11px;letter-spacing:1px;text-transform:uppercase;background:var(--navy-mid);color:var(--accent);font-weight:600}
.sensitivity-table td{padding:14px;text-align:center;font-size:14px;border-bottom:1px solid rgba(255,255,255,0.10)}
.sensitivity-table td.highlight{background:rgba(201,169,78,.1);font-weight:700;color:var(--accent)}
.sensitivity-table td:first-child{text-align:left;font-weight:600;color:var(--gray-400)}
.demo-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:24px;margin-top:40px}
.demo-card{background:var(--navy-light);border-radius:12px;padding:28px;text-align:center;border:1px solid rgba(255,255,255,0.10)}
.demo-card .demo-val{font-size:32px;font-weight:800;margin-bottom:4px}
.demo-card .demo-label{font-size:10px;letter-spacing:2px;text-transform:uppercase;color:var(--gray-400)}
.cta-btn{display:inline-block;background:var(--accent);color:var(--navy);padding:14px 36px;border-radius:6px;font-size:12px;letter-spacing:2px;text-transform:uppercase;font-weight:700;text-decoration:none;transition:all .3s;border:2px solid var(--accent)}
.cta-btn:hover{background:transparent;color:var(--accent)}
.cta-secondary{background:transparent;color:var(--accent);border:2px solid var(--accent)}
.cta-secondary:hover{background:var(--accent);color:var(--navy)}
.risk-list{list-style:none;margin-top:32px}
.risk-list li{display:flex;gap:16px;padding:20px 0;border-bottom:1px solid rgba(255,255,255,0.10)}
.risk-list li:last-child{border-bottom:none}
.risk-num{flex-shrink:0;width:36px;height:36px;background:rgba(201,169,78,.12);border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:14px;font-weight:700;color:var(--accent)}
.risk-list .risk-title{font-size:14px;font-weight:600;margin-bottom:4px}
.risk-list .risk-desc{font-size:13px;color:var(--gray-400);line-height:1.6}
.contact-section{text-align:center;padding:80px 48px}
.contact-section h2{font-family:var(--font-display);font-size:48px;margin-bottom:16px}
.contact-actions{display:flex;justify-content:center;gap:20px;flex-wrap:wrap}
footer{background:var(--navy-light);border-top:1px solid rgba(255,255,255,0.10);padding:40px 48px;text-align:center}
footer p{font-size:11px;color:var(--gray-600);line-height:1.8;max-width:800px;margin:0 auto}
footer .brand{font-family:var(--font-display);font-size:18px;letter-spacing:2px;color:var(--white);margin-bottom:16px}
.divider{width:60px;height:2px;background:var(--accent);margin:24px 0}
.divider-center{margin:24px auto}
.tag{display:inline-block;background:rgba(0,151,167,.15);border:1px solid var(--teal);padding:4px 12px;border-radius:4px;font-size:11px;letter-spacing:1px;color:var(--teal);font-weight:600}
@media(max-width:1100px){
  .sidebar{display:none}.main{margin-left:0}
  .nav-cards{grid-template-columns:repeat(3,1fr)}
  .overview-grid,.highlights-grid{grid-template-columns:1fr}
  .stat-strip{grid-template-columns:repeat(3,1fr)}
  .returns-grid{grid-template-columns:1fr}
}
@media(max-width:600px){
  section{padding:40px 20px}
  .nav-cards{grid-template-columns:1fr 1fr;padding:20px}
  .stat-strip{grid-template-columns:1fr 1fr}
  .hero-stats{flex-direction:column;gap:20px}
}
</style>
</head>
